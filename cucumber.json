{
  "default": {
    "require": [
      "src/steps/**/*.ts",
      "src/support/**/*.ts"
    ],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress",
      "json:reports/cucumber_report.json",
      "html:reports/cucumber_report.html"
    ],
    "paths": ["features/**/*.feature"],
    "publishQuiet": true
  }
}